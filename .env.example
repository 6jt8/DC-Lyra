# ============================================
# Lyra Discord Music Bot - Configuration
# ============================================
# Copy this file to .env and fill in your values.
# Only TOKEN and CLIENT_ID are strictly required for basic operation.
# Database and Spotify are optional but recommended for full features.

# --- REQUIRED: Discord Bot Credentials ---
# Get these from https://discord.com/developers/applications
# Create a bot, enable all Privileged Gateway Intents (Server Members, Message Content, Presence)
TOKEN=your_discord_bot_token_here
CLIENT_ID=your_application_id_here

# --- OPTIONAL: Database (PostgreSQL) ---
# Supports Neon, Supabase, Railway, local Postgres, etc.
# If omitted, playlists, history, language settings, and some stats are disabled (bot still works).
# Example (Neon):
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# Example (Supabase):
# DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# --- OPTIONAL: Spotify API (strongly recommended) ---
# Required for reliable Spotify playlist/track resolution and rich metadata.
# Create app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# --- OPTIONAL: Web Status Page ---
# Simple retro status page served at http://localhost:PORT
# Useful for quick health checks or Docker setups.
PORT=3000

# --- OPTIONAL: Owner & Permissions ---
# Comma-separated Discord user IDs that get owner-only commands/features.
# Leave empty if not needed.
OWNER_ID=your_discord_id_here,other_id_here

# --- OPTIONAL: Appearance & Presence ---
EMBED_COLOR=#e11d2e
ACTIVITY_NAME=YouTube Music | Lyra
ACTIVITY_TYPE=PLAYING
# Valid types: PLAYING, LISTENING, WATCHING, COMPETING, STREAMING

# --- OPTIONAL: Advanced Player Settings ---
# How often (ms) to update the now-playing progress bar / visualizer.
# Lower = smoother but higher CPU. Default: 15000
# PROGRESS_UPDATE_INTERVAL=15000

# --- OPTIONAL: Custom Lavalink Nodes ---
# Override or extend the built-in public nodes.
# Must be a valid JSON array. Keep the single quotes around the whole value.
# Example:
# LAVALINK_NODES='[{"name":"MyNode","host":"lavalink.example.com","port":2333,"password":"youshallnotpass","secure":false}]'
# LAVALINK_NODES='[{"name":"NexCloud V4","host":"n3.nexcloud.in","port":2026,"password":"nexcloud","secure":false}]'

# --- NOTES ---
# • The bot works great with zero extra configuration (uses public Lavalink + in-memory mode).
# • Adding DATABASE_URL unlocks persistent playlists, per-guild language, 24/7 settings, and play history.
# • After changing .env, restart the bot.
# • Never commit your real .env file.
