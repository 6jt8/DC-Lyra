{
  "name": "lyra-music",
  "description": "Lyra — Advanced Discord Music Bot powered by Lavalink & TypeScript",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:bun": "bun run src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "start:bun": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.0"
  },
  "dependencies": {
    "@discordjs/rest": "^2.6.1",
    "@napi-rs/canvas": "^0.1.83",
    "axios": "^1.8.1",
    "discord-api-types": "^0.38.47",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "pg": "^8.21.0",
    "riffy": "^1.0.12",
    "spotify-url-info": "^3.2.18",
    "spotify-web-api-node": "^5.0.2",
    "yt-search": "^2.13.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.7"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.10.0"
  },
  "author": "sayrox106",
  "license": "AGPL-3.0"
}
